# ManaPool API credentials (required)
MANAPOOL_EMAIL=your@email.com
MANAPOOL_TOKEN=your-access-token-here

# Discord webhook URL (optional — omit to disable Discord notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# File paths (optional — defaults shown)
# BUYLIST_PATH=data/buylist.csv
# DB_PATH=data/manabot.db
# REPORTS_DIR=data/reports

# Behavior (optional — defaults shown)
# USE_BULK_EXPORT=false          # true = use ManaPool daily gzip export instead of live endpoint
# MAX_PRICE_AGE_DAYS=1           # re-fetch prices older than this many days
# TREND_WINDOW_DAYS=7            # days of price history used for trend analysis
# TREND_THRESHOLD_PCT=5.0        # % change needed to count as UP or DOWN
